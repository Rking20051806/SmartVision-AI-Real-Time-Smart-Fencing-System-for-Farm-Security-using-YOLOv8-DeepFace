import tkinter as tk
from tkinter import ttk
from PIL import Image, ImageTk
import cv2
from ultralytics import YOLO
from deepface import DeepFace
from datetime import datetime
import csv


# Safe response assignment (non-harmful)
def assign_response(subject_type: str):
    data = {
        "adult_male": ("Medium", "Log + notify owner"),
        "woman": ("Medium", "Log + notify owner"),
        "child": ("High", "Do not engage; notify guardian/authority"),
        "dog": ("Low", "Log only / gentle deterrent"),
        "cat": ("Low", "Log only"),
        "cow": ("Medium", "Notify owner"),
        "goat": ("Medium", "Notify owner"),
        "boar": ("High", "Trigger loud alarm + notify authority"),
    }
    return data.get((subject_type or "").lower(), ("Unknown", "Manual review"))


class SmartVisionApp:
    def __init__(self, root):
        self.root = root
        self.root.title("SmartVision: Intruder Detection and Alerting")
        self.root.geometry("1100x800")

        self.video_label = tk.Label(self.root, bg="black", width=800, height=500)
        self.video_label.pack(pady=10)

        button_frame = tk.Frame(self.root)
        button_frame.pack()

        self.start_button = ttk.Button(button_frame, text="▶️ Start Detection", command=self.start_camera)
        self.start_button.grid(row=0, column=0, padx=10)

        self.stop_button = ttk.Button(button_frame, text="⏹ Stop", command=self.stop_camera)
        self.stop_button.grid(row=0, column=1, padx=10)

        self.info_left = tk.Text(self.root, width=45, height=10, bg="#e7f0f7")
        self.info_left.place(x=20, y=580)

        self.info_right = tk.Text(self.root, width=45, height=10, bg="#e7f0f7")
        self.info_right.place(x=580, y=580)

        self.alert_box = tk.Text(self.root, width=70, height=3, bg="#fdebd0", fg="black", font=("Arial", 12, "bold"))
        self.alert_box.place(x=200, y=730)

        self.cap = None
        self.running = False
        self.model = YOLO("yolov8m.pt")

        self.log_file = None
        self.csv_writer = None
        self._open_log()

    def _open_log(self):
        if self.log_file is None or self.log_file.closed:
            self.log_file = open("detection_log.csv", mode="a", newline="", encoding="utf-8")
            self.csv_writer = csv.writer(self.log_file)
            if self.log_file.tell() == 0:
                self.csv_writer.writerow(["Timestamp", "Type", "Label", "Risk", "Action"])

    def start_camera(self):
        if self.running:
            return

        self._open_log()
        self.cap = cv2.VideoCapture(0)
        if not self.cap.isOpened():
            print("⚠️ Cannot open camera")
            self.cap = None
            return

        self.running = True
        self.update_frame()

    def stop_camera(self):
        self.running = False

        if self.cap:
            self.cap.release()
            self.cap = None

        self.video_label.config(image="")
        self.alert_box.delete(1.0, tk.END)
        self.info_left.delete(1.0, tk.END)
        self.info_right.delete(1.0, tk.END)

        if self.log_file and not self.log_file.closed:
            self.log_file.flush()
            self.log_file.close()

    def on_close(self):
        self.stop_camera()
        self.root.destroy()

    def _safe_crop(self, frame, x1, y1, x2, y2):
        h, w = frame.shape[:2]
        x1, y1 = max(0, x1), max(0, y1)
        x2, y2 = min(w, x2), min(h, y2)
        if x2 <= x1 or y2 <= y1:
            return None
        return frame[y1:y2, x1:x2], (x1, y1, x2, y2)

    def _analyze_person(self, cropped):
        subject_type = "unknown"
        label_text = "Human"

        try:
            analysis = DeepFace.analyze(cropped, actions=["age", "gender"], enforce_detection=False)
            if isinstance(analysis, list):
                analysis = analysis[0]

            age = int(analysis.get("age", 0))
            gender = analysis.get("dominant_gender") or analysis.get("gender") or "Unknown"

            # normalize gender string
            g = str(gender).strip().lower()
            age_group = "Child" if age < 18 else "Adult"
            label_text = f"{gender}, {age_group} ({age})"

            if age < 18:
                subject_type = "child"
            elif g in ("man", "male"):
                subject_type = "adult_male"
            elif g in ("woman", "female"):
                subject_type = "woman"
        except Exception:
            pass

        return label_text, subject_type

    def update_frame(self):
        if not self.running or self.cap is None:
            return

        ret, frame = self.cap.read()
        if not ret:
            self.root.after(100, self.update_frame)
            return

        results = self.model(frame)[0]
        boxes = results.boxes if results is not None else []

        self.info_left.delete(1.0, tk.END)
        self.info_right.delete(1.0, tk.END)
        self.alert_box.delete(1.0, tk.END)

        person_boxes = []
        for box in boxes:
            cls = int(box.cls[0])
            label = self.model.names[cls]
            if label == "person":
                person_boxes.append(box)

        for idx, box in enumerate(person_boxes[:2]):
            x1, y1, x2, y2 = map(int, box.xyxy[0])
            safe = self._safe_crop(frame, x1, y1, x2, y2)
            if safe is None:
                continue
            cropped, (x1, y1, x2, y2) = safe

            label_text, subject_type = self._analyze_person(cropped)
            risk, action = assign_response(subject_type)

            info = f"{label_text}\nRisk: {risk}\nAction: {action}\n\n"
            (self.info_left if idx == 0 else self.info_right).insert(tk.END, info)
            self.alert_box.insert(tk.END, f"🚨 {label_text} → Risk: {risk} | Action: {action}\n")

            ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            self.csv_writer.writerow([ts, "Human", label_text, risk, action])

            cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 255, 0), 2)
            cv2.putText(frame, label_text, (x1, max(20, y1 - 10)), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 0, 0), 2)

        for box in boxes:
            cls = int(box.cls[0])
            label = self.model.names[cls]
            if label in ["dog", "cat", "cow", "goat", "boar"]:
                x1, y1, x2, y2 = map(int, box.xyxy[0])
                risk, action = assign_response(label.lower())
                label_text = f"Animal: {label.capitalize()}"

                info = f"{label_text}\nRisk: {risk}\nAction: {action}\n\n"
                self.info_right.insert(tk.END, info)
                self.alert_box.insert(tk.END, f"🚨 {label_text} → Risk: {risk} | Action: {action}\n")

                ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                self.csv_writer.writerow([ts, "Animal", label, risk, action])

                cv2.rectangle(frame, (x1, y1), (x2, y2), (255, 255, 0), 2)
                cv2.putText(frame, label_text, (x1, max(20, y1 - 10)), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 0, 0), 2)

        if self.log_file and not self.log_file.closed:
            self.log_file.flush()

        frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        img = Image.fromarray(frame_rgb)
        imgtk = ImageTk.PhotoImage(image=img)
        self.video_label.imgtk = imgtk
        self.video_label.configure(image=imgtk)

        self.root.after(30, self.update_frame)


if __name__ == "__main__":
    root = tk.Tk()
    app = SmartVisionApp(root)
    root.protocol("WM_DELETE_WINDOW", app.on_close)
    root.mainloop()